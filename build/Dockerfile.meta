# syntax=docker/dockerfile:1.7

# ============================================================
# Build stage
# ============================================================
FROM golang:1.25-alpine AS builder

LABEL stage=builder

RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG VERSION=dev
ARG COMMIT=none
ARG BUILD_DATE=unknown

ARG TARGETARCH=arm64
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} \
    go build \
      -trimpath \
      -ldflags="-s -w \
        -X main.version=${VERSION} \
        -X main.commit=${COMMIT} \
        -X main.date=${BUILD_DATE}" \
      -o /out/novastor-meta \
      ./cmd/meta

# ============================================================
# Runtime stage
# ============================================================
FROM gcr.io/distroless/static-debian12:nonroot

LABEL org.opencontainers.image.title="novastor-meta" \
      org.opencontainers.image.description="NovaStor Raft-backed metadata service (StatefulSet)" \
      org.opencontainers.image.source="https://github.com/azrtydxb/novastor" \
      org.opencontainers.image.licenses="Apache-2.0"

COPY --from=builder /out/novastor-meta /usr/local/bin/novastor-meta
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/

# gRPC client API
EXPOSE 7001
# Prometheus metrics
EXPOSE 7002

ENTRYPOINT ["/usr/local/bin/novastor-meta"]
