# syntax=docker/dockerfile:1.7

# ============================================================
# Build stage
# ============================================================
FROM golang:1.26.1-alpine AS builder

LABEL stage=builder

# Install build tools required for CGO-free static compilation.
RUN apk add --no-cache git ca-certificates tzdata

WORKDIR /src

# Copy dependency manifests first for layer caching.
COPY go.mod go.sum ./
RUN go mod download

# Copy the full source tree.
COPY . .

# Build arguments for version injection.
ARG VERSION=dev
ARG COMMIT=none
ARG BUILD_DATE=unknown

# Compile a fully static binary with version metadata injected via ldflags.
ARG TARGETARCH=arm64
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} \
    go build \
      -trimpath \
      -ldflags="-s -w \
        -X main.version=${VERSION} \
        -X main.commit=${COMMIT} \
        -X main.date=${BUILD_DATE}" \
      -o /out/novastor-agent \
      ./cmd/agent

# ============================================================
# Runtime stage
# ============================================================
# NOTE: We intentionally use Alpine instead of a distroless base here.
# Distroless images would provide a smaller attack surface, but this
# agent requires util-linux (losetup) and related system tooling to
# manage loop devices for NVMe-oF backing files. Alpine provides these
# tools via apk while still being relatively small.
#
# To mitigate the increased attack surface compared to distroless, we:
#   - Install only the minimal required packages (util-linux, ca-certificates).
#   - Avoid adding a shell or extra utilities beyond what BusyBox/Alpine
#     already provide.
#
# Future hardening: consider replacing this with a custom distroless-style
# image that contains only the novastor-agent binary and the minimal
# losetup/util-linux dependencies needed for NVMe-oF, or an even more
# minimal Alpine variant, once that image is available and validated.
FROM alpine:3.20

LABEL org.opencontainers.image.title="novastor-agent" \
      org.opencontainers.image.description="NovaStor node chunk storage agent (DaemonSet)" \
      org.opencontainers.image.source="https://github.com/azrtydxb/novastor" \
      org.opencontainers.image.licenses="Apache-2.0"

# util-linux : losetup for attaching sparse files as loop devices
# truncate (coreutils) is part of busybox in alpine
RUN apk add --no-cache util-linux ca-certificates

# Copy the compiled binary from the builder stage.
COPY --from=builder /out/novastor-agent /usr/local/bin/novastor-agent

# gRPC listener
EXPOSE 9100
# Prometheus metrics
EXPOSE 9101
# NVMe-oF/TCP target port
EXPOSE 4430

ENTRYPOINT ["/usr/local/bin/novastor-agent"]
